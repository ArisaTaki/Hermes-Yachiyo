{
  "name": "@hermes-yachiyo/desktop-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -s first \"vite --host 127.0.0.1 --port 5174 --strictPort\" \"wait-on http-get://127.0.0.1:5174 && tsc -p tsconfig.electron.json && electron dist-electron/main.js\"",
    "build": "tsc -b && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "start": "electron dist-electron/main.js"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^41.3.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "wait-on": "^9.0.5"
  }
}
